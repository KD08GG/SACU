<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".Detalles">

    /* ────────────────────────────────────────────────────────────── */
    /*                    DECORACIÓN SUPERIOR                         */
    /* ────────────────────────────────────────────────────────────── */

    <View
        android:id="@+id/viewTopArc"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/circle_background"
        app:layout_constraintHeight_percent="0.16"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/viewTopWhite"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/white"
        app:layout_constraintHeight_percent="0.08"
        app:layout_constraintTop_toTopOf="parent" />

    /* ────────────────────────────────────────────────────────────── */
    /*                    DECORACIÓN INFERIOR                         */
    /* ────────────────────────────────────────────────────────────── */

    <View
        android:id="@+id/viewBottomArc"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/circle_background"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintHeight_percent="0.16" />

    <View
        android:id="@+id/viewBottomWhite"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintHeight_percent="0.10" />

    /* ────────────────────────────────────────────────────────────── */
    /*                         TÍTULO                                 */
    /* ────────────────────────────────────────────────────────────── */

    <TextView
        android:id="@+id/txtnotificaciones"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Notificaciones"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/viewTopArc"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/viewTopWhite" />

    /* ────────────────────────────────────────────────────────────── */
    /*                   CONTENEDOR PRINCIPAL                         */
    /* ────────────────────────────────────────────────────────────── */

    <androidx.cardview.widget.CardView
        android:id="@+id/cvContenedor"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="24dp"
        app:cardElevation="4dp"
        app:layout_constraintBottom_toTopOf="@+id/viewBottomArc"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/viewTopArc">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingTop="24dp"
                android:paddingBottom="24dp">

                <!-- Pedido -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="Pedido"
                    android:textColor="@color/gray_medium"
                    android:textSize="27sp" />

                <TextView
                    android:id="@+id/txtNumPedido"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="56"
                    android:textColor="@color/black"
                    android:textSize="49sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtEstado"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="Recogido"
                    android:textColor="@color/gray_medium"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <!-- Separador -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="20dp"
                    android:alpha="0.3"
                    android:background="@color/gray_medium" />

                <!-- Fecha -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Fecha"
                    android:textAlignment="center"
                    android:textColor="@color/gray_medium"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/txtFecha"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="26/10/2026"
                    android:textAlignment="center"
                    android:textColor="@color/black"
                    android:textSize="25sp"
                    android:textStyle="bold" />

                <!-- Hora -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Hora"
                    android:textAlignment="center"
                    android:textColor="@color/gray_medium"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/txtHora"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="10:33 am"
                    android:textAlignment="center"
                    android:textColor="@color/black"
                    android:textSize="25sp"
                    android:textStyle="bold" />

                <!-- Método de Pago -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Método de Pago"
                    android:textAlignment="center"
                    android:textColor="@color/gray_medium"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/txtMetodo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="54 #### ### 204"
                    android:textAlignment="center"
                    android:textColor="@color/black"
                    android:textSize="25sp"
                    android:textStyle="bold" />

                <!-- Folio -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Folio"
                    android:textAlignment="center"
                    android:textColor="@color/gray_medium"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/txtFolio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="129uu348951346"
                    android:textAlignment="center"
                    android:textColor="@color/black"
                    android:textSize="25sp"
                    android:textStyle="bold" />

                <!-- Separador -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:alpha="0.3"
                    android:background="@color/gray_medium" />

                <!-- Productos -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="Productos"
                    android:textColor="@color/gray_medium"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvProductosDetalles"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />

            </LinearLayout>
        </ScrollView>
    </androidx.cardview.widget.CardView>

    /* ────────────────────────────────────────────────────────────── */
    /*              MENÚ DE NAVEGACIÓN (siempre visible)              */
    /* ────────────────────────────────────────────────────────────── */

    <LinearLayout
        android:id="@+id/navBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="8dp"
        android:paddingBottom="24dp"
        android:elevation="8dp"
        android:background="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="4" />

        <ImageButton
            android:id="@+id/btnHome"
            android:layout_width="53dp"
            android:layout_height="53dp"
            android:backgroundTint="@color/transparent"
            android:scaleType="centerCrop"
            android:src="@drawable/icono_home" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/btnCarrito"
            android:layout_width="53dp"
            android:layout_height="53dp"
            android:backgroundTint="@color/transparent"
            android:scaleType="centerCrop"
            android:scaleX="1.2"
            android:scaleY="1.2"
            android:src="@drawable/icono_cart" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/btnNotif"
            android:layout_width="53dp"
            android:layout_height="53dp"
            android:backgroundTint="@color/transparent"
            android:scaleType="centerCrop"
            android:src="@drawable/icono_notifnaranja" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/btnPerfil"
            android:layout_width="53dp"
            android:layout_height="53dp"
            android:backgroundTint="@color/transparent"
            android:scaleType="centerCrop"
            android:src="@drawable/icono_perfil" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="4" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>