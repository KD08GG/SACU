<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/imgProductoCarrito"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:scaleType="centerCrop"
            android:src="@drawable/logito" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/txtNombreCarrito"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hamburguesa Sencilla"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="@color/black" />

            <TextView
                android:id="@+id/txtPrecioCarrito"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$68"
                android:textSize="13sp"
                android:textColor="@color/gray_dark"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/txtCantidadCarrito"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="1"
            android:gravity="center"
            android:textColor="@color/on_secondary"
            android:textStyle="bold"
            android:textSize="14sp"
            android:background="@drawable/circle_background"
            android:backgroundTint="@color/secondary" />

        <ImageButton
            android:layout_marginLeft="10dp"
            android:id="@+id/btnEliminar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:textColor="@color/on_secondary"
            android:textStyle="bold"
            android:textSize="14sp"
            android:background="@drawable/icono_borrar"
            android:backgroundTint="@color/primary" />


    </LinearLayout>

</androidx.cardview.widget.CardView>